# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
# Transaction pooler (port 6543) — app runtime
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — drizzle-kit migrations only
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# NIR encryption key (32 bytes hex — generate with: openssl rand -hex 32)
NIR_ENCRYPTION_KEY=your-256-bit-hex-key

# Ypareo
YPAREO_BASE_URL=https://api.ypareo-neo.com
YPAREO_IDENTIFICATION_TOKEN=your-token

# Gmail SMTP
GMAIL_USER=noreply@edagroupe.fr
GMAIL_APP_PASSWORD=your-app-password

# Claude API (AI extraction)
ANTHROPIC_API_KEY=your-api-key

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
