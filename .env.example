# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
# Transaction pooler (port 6543) — app runtime
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — drizzle-kit migrations only
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Application secret encryption key (32 bytes hex - generate with: openssl rand -hex 32)
APP_ENCRYPTION_KEY=your-256-bit-hex-key

# NIR encryption key (32 bytes hex - generate with: openssl rand -hex 32)
NIR_ENCRYPTION_KEY=your-256-bit-hex-key

# Ypareo
YPAREO_BASE_URL=https://api.ypareo-neo.com
YPAREO_IDENTIFICATION_TOKEN=your-token
# Chemin d'envoi CERFA apprentissage dans Ypareo Neo.
YPAREO_PLACEMENT_PATH=/contrat-apprentissage

# Gmail OAuth2 (connexion Google + Gmail API)
# Créer dans Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# Type : Web application — activer l'API Gmail
# Redirect URIs autorisées :
# - https://<project-ref>.supabase.co/auth/v1/callback
# - http://localhost:3002/auth/gmail/callback (dev) + URL prod
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Claude API (AI extraction)
ANTHROPIC_API_KEY=your-api-key
AI_EXTRACTION_ENABLED=true
AI_EXTRACTION_DPO_APPROVED=true

# Cron digest quotidien
CRON_SECRET=your-random-cron-secret
GMAIL_USER=your-smtp-user
GMAIL_APP_PASSWORD=your-smtp-app-password

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
